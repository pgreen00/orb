{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "declaration": false,
    "experimentalDecorators": true,
    "lib": [
      "DOM",
      "ESNext",
      "dom.iterable"
    ],
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "jsx": "react",
    "jsxFactory": "h",
    "strict": false
  },
  "include": [
    "src",
    "e2e/utils.ts"
  ],
  "exclude": [
    "node_modules"
  ],
}
